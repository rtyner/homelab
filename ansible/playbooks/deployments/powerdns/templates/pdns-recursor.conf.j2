allow-from=10.0.0.0/8
local-port={{ pdns_recursor_port }}
local-address={{ pdns_local_address }}

forward-zones=rtyner.com=YOUR_LOCAL_DNS_IP
forward-zones+=local.rtyner.com=YOUR_LOCAL_DNS_IP

daemon=yes
setgid=pdns-recursor
setuid=pdns-recursor

logging-facility=0
loglevel={{ pdns_loglevel }}

# Prometheus metrics
webserver=yes
webserver-port=8082
webserver-address=0.0.0.0
webserver-allow-from=10.0.0.0/8
api-key={{ pdns_api_key }}